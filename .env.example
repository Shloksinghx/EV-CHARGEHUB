# Copy to .env and fill in your values
VITE_APP_NAME=EV ChargeHub
VITE_APP_VERSION=1.0.0

# OCPI API (simulated — replace with real endpoints in production)
VITE_OCPI_BASE_URL=https://api.your-ocpi-provider.com/v2.2
VITE_OCPI_TOKEN=your_ocpi_token_here

# OCPP WebSocket (simulated)
VITE_OCPP_WS_URL=wss://your-ocpp-server.com/ws

# Maps (Google Maps or Mapbox)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key
VITE_MAPBOX_TOKEN=your_mapbox_token

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry error tracking (optional)
VITE_SENTRY_DSN=https://your-sentry-dsn
